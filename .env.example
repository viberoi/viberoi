# Copy to .env.local (gitignored). pydantic-settings reads it automatically
# via `viberoi_shared.config.get_settings()`.
#
# Values here match defaults in scripts/dev-up.ps1 (and docker-compose.yml).
# Prod values come from AWS Secrets Manager — see .claude/rules/security.md.

VIBEROI_ENV=dev
VIBEROI_SERVICE_NAME=local
VIBEROI_LOG_LEVEL=DEBUG

# ── AWS ─────────────────────────────────────────────────────────────────────
# LocalStack endpoint in dev; leave blank/unset in prod (default AWS endpoints).
VIBEROI_AWS_REGION=us-east-1
VIBEROI_AWS_ENDPOINT_URL=http://localhost:4566

# ── Database ────────────────────────────────────────────────────────────────
# Regular RLS-respecting user; do NOT use viberoi_admin (BYPASSRLS) from services.
VIBEROI_DATABASE_URL=postgresql+asyncpg://viberoi:viberoi@localhost:5432/viberoi

# ── Redis ───────────────────────────────────────────────────────────────────
VIBEROI_REDIS_URL=redis://localhost:6379/0

# ── KMS ─────────────────────────────────────────────────────────────────────
# Alias created by scripts/localstack-init.sh
VIBEROI_KMS_KEY_ID=alias/viberoi-pii

# ── Crypto (Argon2id; OWASP 2024 defaults) ──────────────────────────────────
VIBEROI_ARGON2_TIME_COST=3
VIBEROI_ARGON2_MEMORY_COST_KIB=65536
VIBEROI_ARGON2_PARALLELISM=4

# ── Tracing (optional) ──────────────────────────────────────────────────────
# VIBEROI_OTEL_ENDPOINT=http://localhost:4317

# ── Secrets Manager keys provisioned by scripts/localstack-init.sh ──────────
# (Listed here for reference; the secrets module fetches them by key.)
#   viberoi/dev/lookup_pepper   - peppered HMAC key for searchable encrypted columns
